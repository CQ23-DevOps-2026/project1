def deployPlan = []

def dockerNamespace() {
    return 'vinny2707'
}

def deployNamespace() {
    return 'yas-developer'
}

def shellQuote(String value) {
    return "'" + value.replace("'", "'\"'\"'") + "'"
}

def normalizeBranch(String branch) {
    def normalized = (branch ?: 'main').trim()
    return normalized == '' ? 'main' : normalized
}

def validateBranchName(String branch) {
    if (!(branch ==~ /[A-Za-z0-9._\/-]+/)) {
        error("Invalid branch name: ${branch}")
    }
}

def resolveImageTag(String service, String branch) {
    def normalized = normalizeBranch(branch)
    validateBranchName(normalized)

    if (normalized == 'main') {
        return 'main'
    }

    def ref = "refs/heads/${normalized}"

    def shortSha = sh(
        script: "git ls-remote origin ${shellQuote(ref)} | cut -c1-8",
        returnStdout: true
    ).trim()

    if (!shortSha) {
        error("Cannot resolve branch '${normalized}' for service '${service}'. Push the branch first.")
    }

    return shortSha
}

