def buildDeployPlan() {
    def namespace = dockerNamespace()
    def plan = []

    serviceDefinitions().each { svc ->
        def branch = normalizeBranch(params[svc.param] as String)
        def tag = resolveImageTag(svc.id, branch)

        plan << [
            id: svc.id,
            branch: branch,
            tag: tag,
            chart: svc.chart,
            release: svc.release,
            root: svc.root,
            imageRef: "${namespace}/${svc.image}:${tag}",
            nodePort: svc.nodePort ?: ''
        ]
    }

    return plan
}

def helmSetArgs(Map item) {
    def root = item.root
    def imageRef = item.imageRef as String
    def repository = imageRef.substring(0, imageRef.lastIndexOf(':'))
    def tag = imageRef.substring(imageRef.lastIndexOf(':') + 1)

    def args = [
        "--set ${root}.image.repository=${repository}",
        "--set ${root}.image.tag=${tag}",
        "--set ${root}.image.pullPolicy=Always",
        "--set ${root}.ingress.enabled=false"
    ]

    if (item.nodePort) {
        args << "--set ${root}.service.type=NodePort"
    } else {
        args << "--set ${root}.service.type=ClusterIP"
    }

    if (item.id == 'storefront') {
        args << "--set ${root}.extraEnvs\\[0\\].name=API_BASE_PATH"
        args << "--set ${root}.extraEnvs\\[0\\].value=http://${params.STOREFRONT_HOST}:${params.STOREFRONT_NODE_PORT}/api"
    }

    return args.join(' ')
}

pipeline {
    agent any

    tools {
        maven 'Maven3'
        jdk   'Java21'
    }

    options {
        timestamps()
        ansiColor('xterm')
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '20'))
    }

    parameters {
        string(name: 'WORKER_NODE_HOST', defaultValue: '35.247.188.122', description: 'Public IP/domain of the Kubernetes worker node')
        string(name: 'STOREFRONT_HOST', defaultValue: 'storefront-dev.yas.local.com', description: 'Developer storefront domain')
        string(name: 'BACKOFFICE_HOST', defaultValue: 'backoffice-dev.yas.local.com', description: 'Developer backoffice domain')
        string(name: 'API_HOST', defaultValue: 'api-dev.yas.local.com', description: 'Developer API domain')
        string(name: 'STOREFRONT_NODE_PORT', defaultValue: '31080', description: 'NodePort for storefront-bff')
        string(name: 'BACKOFFICE_NODE_PORT', defaultValue: '31081', description: 'NodePort for backoffice-bff')

        string(name: 'BACKOFFICE_BRANCH', defaultValue: 'main', description: 'Branch for backoffice image')
        string(name: 'BACKOFFICE_BFF_BRANCH', defaultValue: 'main', description: 'Branch for backoffice-bff image')
        string(name: 'STOREFRONT_BRANCH', defaultValue: 'main', description: 'Branch for storefront image')
        string(name: 'STOREFRONT_BFF_BRANCH', defaultValue: 'main', description: 'Branch for storefront-bff image')
        string(name: 'CART_BRANCH', defaultValue: 'main', description: 'Branch for cart image')
        string(name: 'CUSTOMER_BRANCH', defaultValue: 'main', description: 'Branch for customer image')
        string(name: 'INVENTORY_BRANCH', defaultValue: 'main', description: 'Branch for inventory image')
        string(name: 'LOCATION_BRANCH', defaultValue: 'main', description: 'Branch for location image')
        string(name: 'MEDIA_BRANCH', defaultValue: 'main', description: 'Branch for media image')
        string(name: 'ORDER_BRANCH', defaultValue: 'main', description: 'Branch for order image')
        string(name: 'PAYMENT_BRANCH', defaultValue: 'main', description: 'Branch for payment image')
        string(name: 'PAYMENT_PAYPAL_BRANCH', defaultValue: 'main', description: 'Branch for payment-paypal image')
        string(name: 'PRODUCT_BRANCH', defaultValue: 'main', description: 'Branch for product image')
        string(name: 'PROMOTION_BRANCH', defaultValue: 'main', description: 'Branch for promotion image')
        string(name: 'RATING_BRANCH', defaultValue: 'main', description: 'Branch for rating image')
        string(name: 'RECOMMENDATION_BRANCH', defaultValue: 'main', description: 'Branch for recommendation image')
        string(name: 'SAMPLEDATA_BRANCH', defaultValue: 'main', description: 'Branch for sampledata image')
        string(name: 'SEARCH_BRANCH', defaultValue: 'main', description: 'Branch for search image')
        string(name: 'TAX_BRANCH', defaultValue: 'main', description: 'Branch for tax image')
        string(name: 'WEBHOOK_BRANCH', defaultValue: 'main', description: 'Branch for webhook image')
    }

    environment {
        DEPLOY_NAMESPACE = 'yas-developer'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Resolve Image Tags') {
            steps {
                script {
                    deployPlan = buildDeployPlan()

                    echo 'Developer deploy plan:'
                    deployPlan.each { item ->
                        echo "- ${item.id}: branch=${item.branch}, image=${item.imageRef}"
                    }
                }
            }
        }

        stage('Verify Docker Images') {
            steps {
                script {
                    deployPlan.each { item ->
                        sh "docker manifest inspect ${shellQuote(item.imageRef as String)} > /dev/null"
                    }
                }
            }
        }

        stage('Deploy Configuration') {
            steps {
                sh '''
                    set -eu
                    helm repo add stakater https://stakater.github.io/stakater-charts || true
                    helm repo update
                    helm dependency build k8s/charts/yas-configuration
                    helm upgrade --install yas-configuration k8s/charts/yas-configuration \
                        --namespace "$DEPLOY_NAMESPACE" --create-namespace
                '''
            }
        }

        stage('Deploy Applications') {
            steps {
                script {
                    deployPlan.each { item ->
                        def chartPath = "k8s/charts/${item.chart}"
                        def setArgs = helmSetArgs(item as Map)

                        sh "helm dependency build ${shellQuote(chartPath)}"
                        sh "helm upgrade --install ${shellQuote(item.release as String)} ${shellQuote(chartPath)} --namespace ${shellQuote(env.DEPLOY_NAMESPACE)} --create-namespace ${setArgs}"
                    }
                }
            }
        }

        stage('Rollout Status') {
            steps {
                script {
                    deployPlan.each { item ->
                        sh "kubectl rollout status deployment/${shellQuote(item.release as String)} -n ${shellQuote(env.DEPLOY_NAMESPACE)} --timeout=360s"
                    }
                }
            }
        }

        stage('Access Info') {
            steps {
                sh '''
                    set -eu

                    echo "=== Developer namespace pods ==="
                    kubectl get pods -n "$DEPLOY_NAMESPACE" -o wide

                    echo "=== Developer namespace services ==="
                    kubectl get svc -n "$DEPLOY_NAMESPACE" -o wide

                    echo ""
                    echo "Add these entries to the developer machine hosts file:"
                    echo "$WORKER_NODE_HOST $STOREFRONT_HOST"
                    echo "$WORKER_NODE_HOST $BACKOFFICE_HOST"
                    echo "$WORKER_NODE_HOST $API_HOST"

                    echo ""
                    echo "Developer URLs:"
                    echo "Storefront: http://$STOREFRONT_HOST:$STOREFRONT_NODE_PORT"
                    echo "Backoffice:  http://$BACKOFFICE_HOST:$BACKOFFICE_NODE_PORT"
                    echo ""
                    echo "Example API through storefront-bff:"
                    echo "http://$STOREFRONT_HOST:$STOREFRONT_NODE_PORT/api/product/storefront/products/featured?pageNo=0"
                '''
            }
        }
    }
}